# ── Servidor ──────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Base de datos ─────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=tu_password
DB_NAME=micorte

# ── JWT ───────────────────────────────────────
JWT_SECRET=cambia_esto_por_un_string_largo_y_aleatorio
JWT_EXPIRES_IN=1h
JWT_REFRESH_SECRET=otro_string_largo_y_distinto_al_anterior
JWT_REFRESH_EXPIRES_IN=7d

# ── Bcrypt ────────────────────────────────────
BCRYPT_ROUNDS=12

# ── CORS ──────────────────────────────────────
# URLs del frontend separadas por coma
CORS_ORIGINS=http://localhost:5173

# ── Email (Gmail SMTP) ────────────────────────
# Activa "Verificación en 2 pasos" en tu cuenta Google,
# luego genera una App Password en: myaccount.google.com/apppasswords
SMTP_USER=tu@gmail.com
SMTP_PASS=xxxx_xxxx_xxxx_xxxx

# ── URLs del sistema ──────────────────────────
FRONTEND_URL=http://localhost:5173
API_URL=http://localhost:3000

# ── MercadoPago ───────────────────────────────
# Credenciales de prueba en: mercadopago.com/developers
MP_ACCESS_TOKEN=APP_USR-0000000000000000-000000-00000000000000000000000000000000-000000000
MP_WEBHOOK_SECRET=tu_webhook_secret_de_mp

# ── Lealtad ───────────────────────────────────
# Puntos acumulados por cada peso MXN gastado
# 0.1 = 1 punto por cada $10 MXN  |  1 = 1 punto por cada $1 MXN
PUNTOS_POR_PESO=0.1

# ── Twilio (SMS) ──────────────────────────────
# Credenciales en: twilio.com/console
# Si no estan configuradas, los SMS se omiten
# silenciosamente sin afectar email ni el sistema.
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=tu_auth_token_de_twilio
TWILIO_PHONE=+1XXXXXXXXXX
